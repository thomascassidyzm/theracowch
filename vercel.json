{
  "public": true,
  "redirects": [
    { "source": "/chat.html", "destination": "/app.html#chat", "permanent": true }
  ],
  "headers": [
    {
      "source": "/imagine-framework-prompts-enhanced.v2.txt",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/push/send",
      "schedule": "*/15 * * * *"
    }
  ]
}